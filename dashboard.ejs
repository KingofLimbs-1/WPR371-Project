<%- include('../partials/head', { title: title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <h2 class="fw-bold mb-4">
    <i class="bi bi-bar-chart-fill text-warning me-2"></i>Admin Dashboard
  </h2>

  <!-- Summary stats row -->
  <div class="row g-4 mb-5">
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card shadow-sm border-0 bg-dark text-white h-100">
        <div class="card-body text-center py-4">
          <i class="bi bi-ticket-perforated-fill text-warning mb-2" style="font-size:2rem;"></i>
          <h3 class="fw-bold mb-0"><%= totalBookings %></h3>
          <p class="text-white-50 mb-0 small">Total Bookings</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card shadow-sm border-0 bg-warning h-100">
        <div class="card-body text-center py-4">
          <i class="bi bi-people-fill mb-2" style="font-size:2rem;"></i>
          <h3 class="fw-bold mb-0"><%= totalTicketsSold %></h3>
          <p class="mb-0 small">Tickets Sold</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card shadow-sm border-0 bg-success text-white h-100">
        <div class="card-body text-center py-4">
          <i class="bi bi-cash-coin mb-2" style="font-size:2rem;"></i>
          <h3 class="fw-bold mb-0">R<%= totalRevenue.toFixed(2) %></h3>
          <p class="text-white-50 mb-0 small">Total Revenue</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card shadow-sm border-0 bg-info text-white h-100">
        <div class="card-body text-center py-4">
          <i class="bi bi-calendar-event-fill mb-2" style="font-size:2rem;"></i>
          <h3 class="fw-bold mb-0"><%= popularEvents.length %></h3>
          <p class="text-white-50 mb-0 small">Active Events</p>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Popular Events -->
    <div class="col-12 col-lg-7">
      <div class="card shadow-sm">
        <div class="card-header bg-dark text-white fw-semibold">
          <i class="bi bi-trophy me-2 text-warning"></i>Most Booked Events
        </div>
        <% if (popularEvents.length === 0) { %>
          <div class="card-body text-center text-muted py-4">No bookings yet.</div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Event</th>
                  <th>Category</th>
                  <th class="text-center">Booked</th>
                  <th class="text-center">Remaining</th>
                </tr>
              </thead>
              <tbody>
                <% popularEvents.forEach((ev, i) => { %>
                  <tr>
                    <td class="text-muted"><%= i + 1 %></td>
                    <td class="fw-semibold"><%= ev.title %></td>
                    <td><span class="badge bg-warning text-dark text-capitalize"><%= ev.category %></span></td>
                    <td class="text-center"><%= ev.totalBooked %></td>
                    <td class="text-center">
                      <% if (ev.ticketsLeft <= 0) { %>
                        <span class="badge bg-danger">Sold Out</span>
                      <% } else { %>
                        <span class="badge bg-success"><%= ev.ticketsLeft %></span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Bookings by Category -->
    <div class="col-12 col-lg-5">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-dark text-white fw-semibold">
          <i class="bi bi-pie-chart me-2 text-warning"></i>Bookings by Category
        </div>
        <div class="card-body">
          <% if (categoryStats.length === 0) { %>
            <p class="text-muted text-center mt-3">No data yet.</p>
          <% } else { %>
            <% const maxVal = categoryStats[0].totalBooked; %>
            <% categoryStats.forEach(stat => { %>
              <div class="mb-3">
                <div class="d-flex justify-content-between mb-1">
                  <span class="text-capitalize fw-semibold"><%= stat._id %></span>
                  <span class="text-muted small"><%= stat.totalBooked %> tickets</span>
                </div>
                <div class="progress" style="height:10px;">
                  <div
                    class="progress-bar bg-warning"
                    role="progressbar"
                    style="width: <%= Math.round((stat.totalBooked / maxVal) * 100) %>%"
                    aria-valuenow="<%= stat.totalBooked %>"
                    aria-valuemin="0"
                    aria-valuemax="<%= maxVal %>"
                  ></div>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Activity Feed -->
  <div class="card shadow-sm">
    <div class="card-header bg-dark text-white fw-semibold">
      <i class="bi bi-clock-history me-2 text-warning"></i>Recent Bookings
    </div>
    <% if (recentBookings.length === 0) { %>
      <div class="card-body text-center text-muted py-4">No recent bookings.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>User</th>
              <th>Event</th>
              <th class="text-center">Qty</th>
              <th>Booked At</th>
            </tr>
          </thead>
          <tbody>
            <% recentBookings.forEach(b => { %>
              <tr>
                <td>
                  <i class="bi bi-person-circle me-1 text-muted"></i>
                  <%= b.userId ? b.userId.name : 'Unknown' %>
                  <% if (b.userId) { %><br><small class="text-muted"><%= b.userId.email %></small><% } %>
                </td>
                <td class="fw-semibold"><%= b.eventId ? b.eventId.title : '—' %></td>
                <td class="text-center"><%= b.quantity %></td>
                <td class="text-muted small">
                  <%= new Date(b.createdAt).toLocaleString('en-ZA', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

</main>

<%- include('../partials/footer') %>
