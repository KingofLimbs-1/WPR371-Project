<%- include('../partials/head', { title: title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <a href="/events" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left me-1"></i>Back to Events
  </a>

  <div class="row g-4">
    <!-- Event details -->
    <div class="col-12 col-lg-8">
      <div class="card shadow-sm">
        <div class="card-img-top event-img-placeholder d-flex align-items-center justify-content-center bg-dark" style="height:220px;">
          <i class="bi bi-calendar-event text-warning" style="font-size:5rem;"></i>
        </div>
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <span class="badge bg-warning text-dark text-capitalize fs-6"><%= event.category %></span>
            <% if (event.ticketsLeft <= 0) { %>
              <span class="badge bg-danger fs-6">Sold Out</span>
            <% } else { %>
              <span class="badge bg-success fs-6"><%= event.ticketsLeft %> tickets left</span>
            <% } %>
          </div>

          <h2 class="fw-bold mb-3"><%= event.title %></h2>

          <ul class="list-unstyled text-muted mb-4">
            <li class="mb-2">
              <i class="bi bi-calendar3 me-2 text-warning"></i>
              <%= new Date(event.date).toLocaleDateString('en-ZA', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
            </li>
            <li class="mb-2">
              <i class="bi bi-clock me-2 text-warning"></i>
              <%= new Date(event.date).toLocaleTimeString('en-ZA', { hour:'2-digit', minute:'2-digit' }) %>
            </li>
            <li class="mb-2">
              <i class="bi bi-geo-alt me-2 text-warning"></i>
              <%= event.location || 'Venue TBC' %>
            </li>
            <li class="mb-2">
              <i class="bi bi-people me-2 text-warning"></i>
              Capacity: <%= event.capacity %> | Tickets Left: <%= event.ticketsLeft %>
            </li>
          </ul>

          <% if (event.description) { %>
            <h5 class="fw-semibold">About this Event</h5>
            <p class="text-muted"><%= event.description %></p>
          <% } %>

          <!-- Admin controls -->
          <% if (currentUser && currentUser.role === 'admin') { %>
            <hr>
            <div class="d-flex gap-2">
              <a href="/events/<%= event._id %>/edit" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
              </a>
              <form action="/events/<%= event._id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Delete this event? This cannot be undone.')">
                <button type="submit" class="btn btn-outline-danger btn-sm">
                  <i class="bi bi-trash me-1"></i>Delete
                </button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Booking panel -->
    <div class="col-12 col-lg-4">
      <div class="card shadow-sm sticky-top" style="top:80px;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-1">
            <% if (event.price > 0) { %>
              R<%= event.price.toFixed(2) %> <span class="text-muted fw-normal fs-6">per ticket</span>
            <% } else { %>
              <span class="text-success">Free Entry</span>
            <% } %>
          </h5>
          <p class="text-muted small mb-3">
            <i class="bi bi-ticket me-1"></i><%= event.ticketsLeft %> available
          </p>

          <% if (event.ticketsLeft <= 0) { %>
            <div class="alert alert-danger text-center mb-0">
              <i class="bi bi-x-circle me-1"></i>This event is sold out.
            </div>

          <% } else if (!currentUser) { %>
            <div class="alert alert-warning text-center mb-3">
              <i class="bi bi-person-lock me-1"></i>Please log in to book tickets.
            </div>
            <a href="/auth/login" class="btn btn-dark w-100">
              <i class="bi bi-box-arrow-in-right me-1"></i>Login to Book
            </a>

          <% } else { %>
            <form action="/bookings" method="POST">
              <input type="hidden" name="eventId" value="<%= event._id %>">
              <div class="mb-3">
                <label for="quantity" class="form-label fw-semibold">Number of Tickets</label>
                <input
                  type="number"
                  id="quantity"
                  name="quantity"
                  class="form-control"
                  value="1"
                  min="1"
                  max="<%= event.ticketsLeft %>"
                  required
                >
                <div class="form-text">Max <%= event.ticketsLeft %> per booking</div>
              </div>
              <button type="submit" class="btn btn-warning w-100 fw-semibold">
                <i class="bi bi-ticket-perforated me-1"></i>Book Now
              </button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
