<%- include('../partials/head', { title: title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">
      <i class="bi bi-ticket-perforated-fill text-warning me-2"></i>All Events
    </h2>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <div class="d-flex gap-2">
        <a href="/events/new" class="btn btn-warning btn-sm">
          <i class="bi bi-plus-circle me-1"></i>Add Event
        </a>
        <a href="/events/manage" class="btn btn-outline-dark btn-sm">
          <i class="bi bi-gear me-1"></i>Manage
        </a>
      </div>
    <% } %>
  </div>

  <% if (events.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-calendar-x text-muted" style="font-size:4rem;"></i>
      <h5 class="mt-3 text-muted">No events available right now.</h5>
      <a href="/" class="btn btn-outline-dark btn-sm mt-2">Back to Home</a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% events.forEach(event => { %>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="card h-100 shadow-sm event-card">
            <div class="card-img-top event-img-placeholder d-flex align-items-center justify-content-center bg-dark">
              <i class="bi bi-calendar-event text-warning" style="font-size:3rem;"></i>
            </div>
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="badge bg-warning text-dark text-capitalize"><%= event.category %></span>
                <% if (event.ticketsLeft <= 0) { %>
                  <span class="badge bg-danger">Sold Out</span>
                <% } else if (event.ticketsLeft <= 10) { %>
                  <span class="badge bg-warning text-dark"><%= event.ticketsLeft %> left</span>
                <% } %>
              </div>
              <h5 class="card-title fw-bold"><%= event.title %></h5>
              <p class="text-muted small mb-1">
                <i class="bi bi-calendar3 me-1"></i>
                <%= new Date(event.date).toLocaleDateString('en-ZA', { weekday:'short', year:'numeric', month:'short', day:'numeric' }) %>
              </p>
              <p class="text-muted small mb-2">
                <i class="bi bi-geo-alt me-1"></i><%= event.location || 'Venue TBC' %>
              </p>
              <p class="card-text text-muted small flex-grow-1">
                <%= event.description ? event.description.substring(0,100) + '...' : '' %>
              </p>
              <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="fw-bold">
                  <% if (event.price > 0) { %>R<%= event.price.toFixed(2) %>
                  <% } else { %><span class="text-success">Free</span><% } %>
                </span>
                <a href="/events/<%= event._id %>"
                   class="btn btn-sm <%= event.ticketsLeft <= 0 ? 'btn-secondary disabled' : 'btn-dark' %>">
                  <%= event.ticketsLeft <= 0 ? 'Sold Out' : 'View & Book' %>
                  <i class="bi bi-arrow-right ms-1"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
