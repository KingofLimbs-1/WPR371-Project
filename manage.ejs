<%- include('../partials/head', { title: title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">
      <i class="bi bi-gear-fill text-warning me-2"></i>Manage Events
    </h2>
    <a href="/events/new" class="btn btn-warning btn-sm">
      <i class="bi bi-plus-circle me-1"></i>Add Event
    </a>
  </div>

  <% if (events.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-calendar-x text-muted" style="font-size:4rem;"></i>
      <h5 class="mt-3 text-muted">No events yet.</h5>
      <a href="/events/new" class="btn btn-warning btn-sm mt-2">Create First Event</a>
    </div>
  <% } else { %>
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th>Title</th>
              <th>Category</th>
              <th>Date</th>
              <th>Location</th>
              <th class="text-center">Capacity</th>
              <th class="text-center">Left</th>
              <th class="text-end">Price</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% events.forEach(event => { %>
              <tr>
                <td class="fw-semibold"><%= event.title %></td>
                <td>
                  <span class="badge bg-warning text-dark text-capitalize"><%= event.category %></span>
                </td>
                <td class="text-muted small">
                  <%= new Date(event.date).toLocaleDateString('en-ZA', { day:'2-digit', month:'short', year:'numeric' }) %>
                </td>
                <td class="text-muted small"><%= event.location || '—' %></td>
                <td class="text-center"><%= event.capacity %></td>
                <td class="text-center">
                  <% if (event.ticketsLeft <= 0) { %>
                    <span class="badge bg-danger">Sold Out</span>
                  <% } else if (event.ticketsLeft <= 10) { %>
                    <span class="badge bg-warning text-dark"><%= event.ticketsLeft %></span>
                  <% } else { %>
                    <span class="badge bg-success"><%= event.ticketsLeft %></span>
                  <% } %>
                </td>
                <td class="text-end">
                  <% if (event.price > 0) { %>R<%= event.price.toFixed(2) %>
                  <% } else { %><span class="text-success small">Free</span><% } %>
                </td>
                <td class="text-center">
                  <div class="d-flex justify-content-center gap-1">
                    <a href="/events/<%= event._id %>" class="btn btn-sm btn-outline-dark" title="View">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="/events/<%= event._id %>/edit" class="btn btn-sm btn-outline-warning" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form action="/events/<%= event._id %>?_method=DELETE" method="POST"
                          onsubmit="return confirm('Delete \'<%= event.title %>\'? This cannot be undone.')">
                      <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <p class="text-muted small mt-2"><%= events.length %> event<%= events.length !== 1 ? 's' : '' %> total</p>
  <% } %>
</main>

<%- include('../partials/footer') %>
