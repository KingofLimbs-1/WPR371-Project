<%- include('../partials/head', { title: title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <h2 class="fw-bold mb-4">
    <i class="bi bi-journal-bookmark-fill text-warning me-2"></i>My Bookings
  </h2>

  <% if (bookings.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-ticket text-muted" style="font-size:4rem;"></i>
      <h5 class="mt-3 text-muted">You have no bookings yet.</h5>
      <a href="/events" class="btn btn-warning btn-sm mt-2">Browse Events</a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% bookings.forEach(booking => { %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <% if (booking.eventId) { %>
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <span class="badge bg-warning text-dark text-capitalize"><%= booking.eventId.category %></span>
                  <small class="text-muted">
                    Booked <%= new Date(booking.createdAt).toLocaleDateString('en-ZA') %>
                  </small>
                </div>

                <h5 class="fw-bold mb-2"><%= booking.eventId.title %></h5>

                <p class="text-muted small mb-1">
                  <i class="bi bi-calendar3 me-1"></i>
                  <%= new Date(booking.eventId.date).toLocaleDateString('en-ZA', { weekday:'short', year:'numeric', month:'short', day:'numeric' }) %>
                </p>
                <p class="text-muted small mb-2">
                  <i class="bi bi-geo-alt me-1"></i><%= booking.eventId.location || 'Venue TBC' %>
                </p>

                <div class="d-flex justify-content-between align-items-center mt-3">
                  <span class="fw-semibold">
                    <i class="bi bi-ticket-perforated me-1 text-warning"></i>
                    <%= booking.quantity %> ticket<%= booking.quantity !== 1 ? 's' : '' %>
                  </span>
                  <span class="fw-bold">
                    <% if (booking.eventId.price > 0) { %>
                      R<%= (booking.eventId.price * booking.quantity).toFixed(2) %>
                    <% } else { %>
                      <span class="text-success">Free</span>
                    <% } %>
                  </span>
                </div>

                <hr>
                <div class="d-flex gap-2">
                  <a href="/events/<%= booking.eventId._id %>" class="btn btn-sm btn-outline-dark">
                    <i class="bi bi-eye me-1"></i>View Event
                  </a>
                  <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Cancel this booking? Tickets will be released.')">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                  </form>
                </div>

              <% } else { %>
                <div class="text-muted">
                  <i class="bi bi-exclamation-circle me-1"></i>
                  Event no longer available.
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <p class="text-muted small mt-3"><%= bookings.length %> booking<%= bookings.length !== 1 ? 's' : '' %> total</p>
  <% } %>
</main>

<%- include('../partials/footer') %>
