<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
  <div class="container">

    <!-- Brand -->
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-calendar-event-fill text-warning me-2"></i>EventHub
    </a>

    <!-- Mobile toggle -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Links -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/"><i class="bi bi-house me-1"></i>Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/events"><i class="bi bi-ticket-perforated me-1"></i>Events</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/contact"><i class="bi bi-envelope me-1"></i>Contact</a>
        </li>

        <!-- Admin only links -->
        <% if (currentUser && currentUser.role === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link text-warning" href="/events/manage">
              <i class="bi bi-gear me-1"></i>Manage Events
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-warning" href="/bookings/dashboard">
              <i class="bi bi-bar-chart me-1"></i>Dashboard
            </a>
          </li>
        <% } %>
      </ul>

      <!-- Auth links -->
      <ul class="navbar-nav">
        <% if (currentUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/bookings/my-bookings">
              <i class="bi bi-journal-bookmark me-1"></i>My Bookings
            </a>
          </li>
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle"
              href="#"
              data-bs-toggle="dropdown"
            >
              <i class="bi bi-person-circle me-1"></i><%= currentUser.name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <form action="/auth/logout" method="POST">
                  <button class="dropdown-item text-danger" type="submit">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                  </button>
                </form>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/auth/login">
              <i class="bi bi-box-arrow-in-right me-1"></i>Login
            </a>
          </li>
          <li class="nav-item">
            <a class="btn btn-warning btn-sm ms-2 my-auto" href="/auth/register">
              Register
            </a>
          </li>
        <% } %>
      </ul>
    </div>

  </div>
</nav>

<!-- Flash messages -->
<div class="container mt-3">
  <% if (successMessage && successMessage.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle me-2"></i><%= successMessage %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (errorMessage && errorMessage.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-circle me-2"></i><%= errorMessage %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
</div>
